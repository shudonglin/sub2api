# =============================================================================
# Sub2API — Supabase / Hosted PostgreSQL Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.supabase.example .env
#   nano .env
#
# Then start with:
#   docker compose -f docker-compose.supabase.yml up -d
# =============================================================================

# -----------------------------------------------------------------------------
# Database — hosted PostgreSQL connection string (REQUIRED)
# -----------------------------------------------------------------------------
# Get your connection string from:
#   Supabase Dashboard -> Settings -> Database -> Connection string -> URI
#
# Session pooler (recommended, port 5432 — supports prepared statements required by lib/pq):
#   postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-[N]-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
#
# Transaction pooler (port 6543 — NOT compatible with lib/pq prepared statements):
#   postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-[N]-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
#
# Direct connection (port 5432 via db.[REF].supabase.co):
#   postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-[N]-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# Redis (still required locally)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=

# Redis 内存限制 — 按 VM 可用内存选择：
#   1 GB VM → 64mb | 2 GB VM → 128mb | 4 GB VM → 256mb | 8 GB+ VM → 512mb
REDIS_MAXMEMORY=128mb
# 淘汰策略：allkeys-lru（推荐） | allkeys-lfu | volatile-lru | noeviction
REDIS_MAXMEMORY_POLICY=allkeys-lru

# -----------------------------------------------------------------------------
# Admin Account
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@sub2api.local
# Leave empty to auto-generate (will be shown in logs on first run)
ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# JWT (auto-generated if empty; set a fixed value to survive restarts)
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
JWT_SECRET=

# -----------------------------------------------------------------------------
# TOTP encryption key (auto-generated if empty; set a fixed value to survive restarts)
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Provider credential encryption key (REQUIRED in release mode)
# -----------------------------------------------------------------------------
# Encrypts upstream provider credentials (OAuth tokens, API keys) at rest in
# the database. Startup FAILS in release mode when this is unset.
# Generate: openssl rand -hex 32
SECURITY_CREDENTIAL_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Asia/Shanghai
